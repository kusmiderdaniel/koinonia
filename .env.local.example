# Supabase Configuration
# Copy this file to .env.local and fill in your values

# ========================================
# OPTION 1: LOCAL DEVELOPMENT (recommended)
# ========================================
# These values are auto-generated when you run `supabase start`
# Check the output of `supabase status` for your local instance keys
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-local-anon-key-from-supabase-status
SUPABASE_SERVICE_ROLE_KEY=your-local-service-role-key-from-supabase-status

# ========================================
# OPTION 2: PRODUCTION (Supabase Cloud)
# ========================================
# Get these from your Supabase project dashboard: Settings > API
# NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-production-anon-key
# SUPABASE_SERVICE_ROLE_KEY=your-production-service-role-key

# App Configuration
NEXT_PUBLIC_SITE_URL=http://localhost:3000
